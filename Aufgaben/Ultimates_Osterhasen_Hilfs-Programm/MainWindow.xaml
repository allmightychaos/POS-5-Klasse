<Window x:Class="Ultimates_Osterhasen_Hilfs_Programm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ultimates_Osterhasen_Hilfs_Programm"
        mc:Ignorable="d"
        Title="Ultimatives Osterhasen Hilfs-Programm"
        Height="700" Width="1000"
        MinHeight="600" MinWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Eingabeformular -->
            <RowDefinition Height="*"/>
            <!-- Karte + Liste -->
            <RowDefinition Height="Auto"/>
            <!-- Steuerung -->
            <RowDefinition Height="Auto"/>
            <!-- Statusleiste -->
        </Grid.RowDefinitions>

        <!-- ===== Zeile 0: Eingabeformular ===== -->
        <Border Grid.Row="0" Background="#FFF8E7" BorderBrush="#E0C060" BorderThickness="0,0,0,2" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🐣 Person registrieren:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="NameBox" Width="150" Margin="0,0,15,0" Padding="4,2"
                         ToolTip="Vor- und Nachname der Person"/>

                <TextBlock Text="Longitude:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="LonBox" Width="100" Margin="0,0,15,0" Padding="4,2"
                         ToolTip="Längengrad (z.B. 16.245000) – muss im Bereich 16.2097 bis 16.2810 liegen"/>

                <TextBlock Text="Latitude:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="LatBox" Width="100" Margin="0,0,15,0" Padding="4,2"
                         ToolTip="Breitengrad (z.B. 47.815000) – muss im Bereich 47.7869 bis 47.8465 liegen"/>

                <Button Content="➕ Hinzufügen" Click="AddPerson_Click"
                        Padding="10,4" Background="#4CAF50" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- ===== Zeile 1: Hauptinhalt ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Personenliste -->
            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                        <TextBlock Text="📋 Registrierte Personen"
                                   FontWeight="Bold" Padding="8,6"/>
                    </Border>
                    <ListBox x:Name="PersonListBox"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,3">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock FontSize="10" Foreground="Gray">
                                        <Run Text="Lon: "/>
                                        <Run Text="{Binding Longitude, StringFormat=F6}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="Gray">
                                        <Run Text="Lat: "/>
                                        <Run Text="{Binding Latitude, StringFormat=F6}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Karte -->
            <Grid Grid.Column="1" x:Name="MapContainer" Background="#E8F4E8"
                  SizeChanged="MapContainer_SizeChanged">
                <!-- Stadtkarte als Hintergrund -->
                <Image x:Name="MapImage"
                       Source="https://www.eduvidual.at/pluginfile.php/8567458/mod_page/content/2/Stadtplan-Wiener-Neustadt.jpg"
                       Stretch="Fill"/>
                <!-- Canvas für Zeichnungen (Punkte, Linien) -->
                <Canvas x:Name="MapCanvas"
                        Background="Transparent"
                        MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                        Cursor="Cross"/>
            </Grid>
        </Grid>

        <!-- ===== Zeile 2: Steuerungsleiste ===== -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="👥 Anzahl Helfer:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                <TextBox x:Name="HelperCountBox" Text="3" Width="40" Padding="4,2"
                         VerticalAlignment="Center" Margin="0,0,15,0"
                         ToolTip="Anzahl der Helfer für die Aufteilung (1–10)"/>

                <Button Content="🎨 Aufteilen (K-Means)" Click="Cluster_Click"
                        Padding="10,5" Margin="0,0,10,0"
                        Background="#2196F3" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        ToolTip="Personen mit K-Means auf Helfer aufteilen"/>

                <Button x:Name="PlanRoutesButton"
                        Content="🗺️ Routen planen" Click="PlanRoutes_Click"
                        Padding="10,5" Margin="0,0,10,0"
                        Background="#FF9800" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        ToolTip="Startpunkte auf der Karte klicken, dann Routen berechnen"/>

                <Button Content="🔄 Zurücksetzen" Click="Reset_Click"
                        Padding="10,5"
                        Background="#9E9E9E" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        ToolTip="Clustering und Routen zurücksetzen"/>

                <Separator Margin="15,0"/>

                <!-- Legende -->
                <TextBlock Text="Legende:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                <Ellipse Width="12" Height="12" Fill="#228B22" VerticalAlignment="Center" Margin="0,0,3,0"/>
                <TextBlock Text="Ungeteilt" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock x:Name="LegendPanel" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ===== Zeile 3: Statusleiste ===== -->
        <Border Grid.Row="3" Background="#333" Padding="10,4">
            <TextBlock x:Name="StatusText"
                       Foreground="White" FontSize="12"
                       Text="Bereit. Bitte Personen registrieren."/>
        </Border>
    </Grid>
</Window>
