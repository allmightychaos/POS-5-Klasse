<Window x:Class="Bilderverwaltungsprogramm.AlbumWaehlenDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bilderverwaltungsprogramm"
        mc:Ignorable="d"
        Title="AlbumWaehlenDialog" Height="150" Width="300">
    <Grid>
        <StackPanel Margin="10">
            <ComboBox x:Name="AlbumComboBox" ItemsSource="{Binding}" DisplayMemberPath="AlbumName"/>

            <Button Content="OK" 
                    Click="OK_Click" 
                    Margin="0, 10, 0, 0" 
                    Width="50" 
                    HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</Window>
