<Window x:Class="Bilderverwaltungsprogramm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bilderverwaltungsprogramm"
        mc:Ignorable="d"
        Closed="Window_Closed"
        Title="MainWindow" Height="450" Width="800">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AlbumErstellenCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding BildHinzufuegenCommand}"/>
        <KeyBinding Key="M" Modifiers="Ctrl" Command="{Binding BildVerschiebenCommand}"
                CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"/>
        <KeyBinding Key="Delete" Command="{Binding BildLoeschenCommand}"
                CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding RotateClock90Command}"
                CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"/>
        <KeyBinding Key="R" Modifiers="Ctrl+Shift" Command="{Binding RotateCounter90Command}"
                CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"/>
        <KeyBinding Key="R" Modifiers="Ctrl+Alt" Command="{Binding Rotate180Command}"
                CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"/>
    </Window.InputBindings>

    <Grid FlowDirection="LeftToRight">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menübar -->
        <Menu Grid.Row="0">
            <!-- Datei -->
            <MenuItem Header="_Datei">
                <!-- Neues Album -->
                <MenuItem Header="_Neues Album" InputGestureText="Strg+N" Command="{Binding AlbumErstellenCommand}">
                    <MenuItem.Icon>
                        <Image Source="/Icons/image-gallery.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <!-- Bild hinzufügen -->
                <MenuItem Header="Bilder _hinzufügen" InputGestureText="Strg+O" Command="{Binding BildHinzufuegenCommand}">
                    <MenuItem.Icon>
                        <Image Source="/Icons/image-add.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <!-- Bild verschieben -->
                <MenuItem Header="Bilder in Album _verschieben"
                          InputGestureText="Strg+M"
                          Command="{Binding BildVerschiebenCommand}"
                          CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"
                          >
                    <MenuItem.Icon>
                        <Image Source="/Icons/image-move.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <!-- Bild löschen -->
                <MenuItem Header="Bilder _löschen"
                          InputGestureText="Entf" 
                          Command="{Binding BildLoeschenCommand}"
                          CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"
                          >
                    <MenuItem.Icon>
                        <Image Source="/Icons/image-delete.png"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Bearbeiten -->
            <MenuItem Header="_Bearbeiten">
                <MenuItem Header="Rotieren: 90° _im Uhrzeigersinn" 
                          InputGestureText="Strg+R"
                          Command="{Binding RotateClock90Command}"
                          CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"
                          >
                    <MenuItem.Icon>
                        <Image Source="/Icons/rotate-right.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Rotieren: 90° _gegen Uhrzeigersinn" 
                          InputGestureText="Strg+Shift+R"
                          Command="{Binding RotateCounter90Command}"
                          CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"
                          >
                    <MenuItem.Icon>
                        <Image Source="/Icons/rotate-left.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Rotieren: 180°" 
                          InputGestureText="Strg+Alt+R"
                          Command="{Binding Rotate180Command}"
                          CommandParameter="{Binding ElementName=BildListBox, Path=SelectedItems}"
                          >
                    <MenuItem.Icon>
                        <Image Source="/Icons/rotate-180.png"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        
        <!-- Album-Auswahl -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
            <TextBlock Text="Aktuelles Album: " VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
            <ComboBox Width="200"
                      ItemsSource="{Binding AlbumAuswahl}"
                      SelectedItem="{Binding AusgAlbum}"
                      >
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding AlbumName}" FontWeight="Bold"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <!-- Bildgallerie -->
        <ListBox x:Name="BildListBox"
                 Grid.Row="2" 
                 Margin="5"
                 SelectionMode="Multiple"
                 ItemsSource="{Binding AusgAlbum.Bilddatei}"
                 >
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical" Width="195" Height="110">
                        <Image Source="{Binding Bildquelle}" Height="75"/>
                        <TextBlock Text="{Binding Bildname}" 
                                   Height="35" 
                                   TextWrapping="Wrap"
                                   Background="LightGray"
                                   Padding="3, 0"
                                   VerticalAlignment="Center"
                                   />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
