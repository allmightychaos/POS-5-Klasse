<Window x:Class="Taschenrechner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Taschenrechner.UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="400"
        KeyDown="OnKeyDownHandler" 
        >

    <Grid Background="#222831">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="0.75*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <!-- ZWISCHENRECHNUNG GRID -->
        <Grid Grid.Row="0">
            <TextBox x:Name="Zwischenrechnung" 
                     Text=""
                     FontSize="20" 
                     HorizontalContentAlignment="Right" 
                     VerticalContentAlignment="Bottom" 
                     Foreground="LightSlateGray"
                     Background="Transparent"
                     />  
        </Grid>

        <!-- OUTPUT GRID -->
        <Grid Grid.Row="1">
            <TextBox x:Name="Output" 
                     Text="0"
                     FontSize="48" 
                     HorizontalContentAlignment="Right" 
                     VerticalContentAlignment="Top" 
                     Foreground="White"
                     Background="Transparent"
                     />
        </Grid>

        <!-- CALCULATION GRID -->
        <Grid Grid.Row="2" Margin="5,0,5,5">
            <Grid.Resources>
                <Style TargetType="Button">
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Background" Value="#FF393E46"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="28"/>
                </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="button_bracket_open" Grid.Row="0" Grid.Column="0" Background="#30343b" Content="(" Click="buttonOpenBracketClicked"/>
            <Button x:Name="button_bracket_close" Grid.Row="0" Grid.Column="1" Background="#30343b" Content=")" Click="buttonClosedBracketClicked"/>
            <Button x:Name="button_clear" Grid.Row="0" Grid.Column="2" Background="#30343b" Content="C" Click="buttonClearClicked"/>
            <Button x:Name="button_delete" Grid.Row="0" Grid.Column="3" Background="#282c32" Content="⌫" Click="buttonDeleteClicked"/>

            <Button x:Name="button_x" Grid.Row="1" Grid.Column="0" Background="#30343b" Content="x" Click="buttonVariableClicked"/>
            <Button x:Name="button_y" Grid.Row="1" Grid.Column="1" Background="#30343b" Content="y" Click="buttonVariableClicked"/>
            <Button x:Name="button_z" Grid.Row="1" Grid.Column="2" Background="#30343b" Content="z" Click="buttonVariableClicked"/>
            <Button x:Name="button_devide" Grid.Row="1" Grid.Column="3" Background="#30343b" Content="÷" Click="buttonOperaterClicked"/>

            <Button x:Name="button_7" Grid.Row="2" Grid.Column="0" Content="7" Click="buttonNumbersClicked"/>
            <Button x:Name="button_8" Grid.Row="2" Grid.Column="1" Content="8" Click="buttonNumbersClicked"/>
            <Button x:Name="button_9" Grid.Row="2" Grid.Column="2" Content="9" Click="buttonNumbersClicked"/>
            <Button x:Name="button_times" Grid.Row="2" Grid.Column="3" Background="#30343b" Content="×" Click="buttonOperaterClicked"/>

            <Button x:Name="button_4" Grid.Row="3" Grid.Column="0" Content="4" Click="buttonNumbersClicked"/>
            <Button x:Name="button_5" Grid.Row="3" Grid.Column="1" Content="5" Click="buttonNumbersClicked"/>
            <Button x:Name="button_6" Grid.Row="3" Grid.Column="2" Content="6" Click="buttonNumbersClicked"/>
            <Button x:Name="button_minus" Grid.Row="3" Grid.Column="3" Background="#30343b" Content="-" Click="buttonOperaterClicked"/>

            <Button x:Name="button_1" Grid.Row="4" Grid.Column="0" Content="1" Click="buttonNumbersClicked"/>
            <Button x:Name="button_2" Grid.Row="4" Grid.Column="1" Content="2" Click="buttonNumbersClicked"/>
            <Button x:Name="button_3" Grid.Row="4" Grid.Column="2" Content="3" Click="buttonNumbersClicked"/>
            <Button x:Name="button_plus" Grid.Row="4" Grid.Column="3" Background="#30343b" Content="+" Click="buttonOperaterClicked"/>

            <Button x:Name="button_power" Grid.Row="5" Grid.Column="0" Background="#30343b" Content="^" Click="buttonOperaterClicked"/>
            <Button x:Name="button_0" Grid.Row="5" Grid.Column="1" Content="0" Click="buttonNumbersClicked"/>
            <Button x:Name="button_comma" Grid.Row="5" Grid.Column="2" Background="#30343b" Content="," Click="buttonCommaClicked"/>
            <Button x:Name="button_equals" Grid.Row="5" Grid.Column="3" Background="DarkSlateGray" Content="=" Click="buttonEqualClicked"/>
        </Grid>
    </Grid>
</Window>
